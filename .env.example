# Solana network for development (use devnet / testnet)
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Helius RPC endpoint — kept private (server-side only, never in the client bundle).
# All browser RPC/DAS calls go through the /api/rpc proxy which reads this var.
# For DAS API support (getAssetsByGroup, Discover, Analytics) use Helius:
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# If not set, the proxy falls back to the public Solana endpoint (no DAS support).

# Arweave upload via Irys (devnet for testing, mainnet for production)
# NEXT_PUBLIC_IRYS_NODE=https://devnet.irys.xyz

# Explorer base URL (optional)
# NEXT_PUBLIC_EXPLORER_URL=https://explorer.solana.com

# Set to "true" for local development (skips Arweave uploads, stores files locally)
# Set to "false" or remove for production (uses real Arweave/Irys)
# NEXT_PUBLIC_USE_LOCAL_STORAGE=true

# ── Launchpad Registry (Wave 4.5) ──────────────────────────────────────
# Vercel KV (Upstash Redis) for the launchpad collection allowlist (production).
# KV_REST_API_URL=https://your-kv-instance.upstash.io
# KV_REST_API_TOKEN=your-upstash-token

# Local JSON file fallback for registry when KV vars are unset (dev only).
# LOCAL_KV_PATH=/tmp/lp-registry.json

# Optional: if set, the register-collection API requires Bearer auth.
# LAUNCHPAD_REGISTRY_SECRET=your-secret-here

# Suppress Node.js warnings (e.g. bigint native bindings) in Vercel logs.
# NODE_OPTIONS=--no-warnings
